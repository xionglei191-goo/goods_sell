# Database
DATABASE_URL="postgresql://user:password@localhost:5432/huaqi_mall"

# Auth.js
NEXTAUTH_SECRET="your-secret-key"
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="your-secret-key"

# AMap
AMAP_KEY="your-amap-key"
AMAP_SECRET="your-amap-security-js-code"
NEXT_PUBLIC_AMAP_KEY="your-amap-key"
NEXT_PUBLIC_AMAP_SECURITY_CODE="your-amap-security-js-code"

# AI - primary Anthropic-compatible gateway
AI_BASE_URL="https://your-ai-host/v1"
AI_API_KEY="your-ai-key"
AI_MODEL="qwen3.6-plus"
AI_TIMEOUT_MS="60000"

# AI - optional provider fallback keys. Leave empty unless directly using DashScope or DeepSeek.
DASHSCOPE_API_KEY=""
DEEPSEEK_API_KEY=""

# WeChat Mini Program
WECHAT_MINI_APP_ID="your-mini-program-app-id"
WECHAT_MINI_APP_SECRET="your-mini-program-secret"

# WeChat Official Account
WECHAT_OFFICIAL_APP_ID="your-official-account-app-id"
WECHAT_OFFICIAL_APP_SECRET="your-official-account-secret"
WECHAT_OFFICIAL_ORDER_TEMPLATE_ID="your-order-status-template-id"

# WeChat Pay
WECHAT_PAY_MCH_ID="your-mch-id"
WECHAT_PAY_SERIAL_NO="your-merchant-cert-serial-no"
WECHAT_PAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----"
WECHAT_PAY_APIV3_KEY="your-32-byte-apiv3-key"
WECHAT_PAY_PLATFORM_CERT="-----BEGIN CERTIFICATE-----\\n...\\n-----END CERTIFICATE-----"
WECHAT_PAY_NOTIFY_URL="https://your-domain.com/api/wechat/pay/notify"

# App
NEXT_PUBLIC_APP_NAME="华启商城"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Product image material storage
# LOCAL writes to public/images/products. CLOUDFLARE_R2 and ALIYUN_OSS require the provider settings below.
IMAGE_MATERIAL_STORAGE_PROVIDER="LOCAL"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_BUCKET=""
OSS_REGION=""
OSS_PUBLIC_BASE_URL=""
